---
apiVersion: user.keycloak.crossplane.io/v1alpha1
kind: Groups
metadata:
  name: {{ tenancy }}-admin-group-mapping
spec:
  forProvider:
    realmId: azimuth-users
    userIdRef:
      name: {{ tenancy }}-admin
    groupIdsRefs:
      - name: {{ tenancy }}
        policy: Always
  providerConfigRef:
    name: keycloak-config
